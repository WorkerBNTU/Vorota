# Скопируйте в .env и заполните. Подробности: docs/runbook.md
# В production обязательны: DJANGO_SECRET_KEY (уникальный!), ADMIN_PASSWORD, SITE_URL,
# ALLOWED_HOSTS с доменом, CSRF_TRUSTED_ORIGINS=https://…, DEBUG=False

# Django — локально True; на сервере обязательно False
DEBUG=True
# НЕ оставляйте значение из примера на проде — entrypoint его отклонит
DJANGO_SECRET_KEY=dev-local-only-change-me
# "frontend" нужен для prerender; на проде добавьте vorota-rb.by,www.vorota-rb.by
ALLOWED_HOSTS=localhost,127.0.0.1,frontend

# Публичный адрес сайта — для sitemap.xml и robots.txt (без / на конце)
SITE_URL=https://vorota-rb.by

# Database (для локальной разработки используется SQLite по умолчанию)
# DB_ENGINE=postgresql
# DB_NAME=vorota
# DB_USER=vorota
# DB_PASSWORD=замените-на-сильный-пароль
# DB_HOST=localhost
# DB_PORT=5432

# Redis для rate-limit (в Docker/prod обязателен — compose задаёт сам)
# REDIS_URL=redis://localhost:6379/0

# За nginx — доверять X-Real-IP / X-Forwarded-* (в Docker/prod: True)
TRUST_PROXY_HEADERS=False
# HTTPS-редирект Django (обычно False: TLS на nginx). True только с TRUST_PROXY_HEADERS
# SECURE_SSL_REDIRECT=False
# HSTS в секундах (0 = выкл.; включайте только при реальном HTTPS снаружи)
# SECURE_HSTS_SECONDS=0
# SECURE_HSTS_PRELOAD=False

# CORS / CSRF — локально localhost:5173; в Docker/prod задайте явно (compose требует):
#   CORS_ALLOWED_ORIGINS=https://vorota-rb.by
#   CSRF_TRUSTED_ORIGINS=https://vorota-rb.by,https://www.vorota-rb.by
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Telegram — дублирование заявок (пусто = только запись в CRM, без уведомлений)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Админ — в production ОБЯЗАТЕЛЬНО задать надёжный пароль
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Встроенная Django-admin (/django-admin/) — по умолчанию выключена
ENABLE_DJANGO_ADMIN=False
# OpenAPI schema + Swagger/ReDoc (в DEBUG включаются сами)
ENABLE_API_DOCS=False

# Rate limiting POST-запросов (/api/leads/, /api/auth/login/, …)
# /api/admin/ не лимитируется
RATE_LIMIT_REQUESTS=5
RATE_LIMIT_WINDOW=60
# При падении Redis: True = 429 (прод-дефолт), False = in-memory fallback
# RATE_LIMIT_FAIL_CLOSED=True

# Sentry — мониторинг ошибок (пусто = выключено)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend (Vite build-arg в Docker): browser-проект Sentry
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
